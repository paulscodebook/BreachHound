{
    "actorSpecification": 1,
    "fields": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
            "email": {
                "type": "string",
                "description": "The audited email address."
            },
            "website": {
                "type": "string",
                "description": "The domain name of the checked website."
            },
            "name": {
                "type": "string",
                "description": "The name of the checked service."
            },
            "status": {
                "type": "string",
                "description": "The result status of the check.",
                "enum": ["found", "not_found", "rate_limited"]
            },
            "emailRecovery": {
                "type": "string",
                "description": "Masked recovery email address (if found)."
            },
            "phoneNumber": {
                "type": "string",
                "description": "Masked phone number (if found)."
            },
            "others": {
                "type": "object",
                "description": "Additional user details returned by the service."
            }
        },
        "required": ["email", "website", "name", "status"]
    },
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": ["email", "website", "status", "emailRecovery", "phoneNumber"]
            },
            "display": {
                "component": "table",
                "properties": {
                    "email": { "label": "Audited Email" },
                    "website": { "label": "Service Domain" },
                    "status": { "label": "Check Status" },
                    "emailRecovery": { "label": "Recovery Email" },
                    "phoneNumber": { "label": "Phone Number" }
                }
            }
        }
    }
}
